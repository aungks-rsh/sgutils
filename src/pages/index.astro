---
import { PREFIX_DESCRIPTIONS } from "../lib/identifiers";
import { SITE } from "../config/site";

const pageTitle = "Singapore NRIC & FIN Generator — sgutils";
const pageDescription =
  "Generate and validate format-valid Singapore NRIC and FIN numbers for testing and development. Free, privacy-friendly, runs entirely in your browser.";
const pageUrl = new URL(Astro.url.pathname, SITE.url).toString();
const ogImage = new URL("/og.png", SITE.url).toString();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Singapore NRIC & FIN Generator",
  url: pageUrl,
  description: pageDescription,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Any",
  browserRequirements: "Requires JavaScript",
  offers: { "@type": "Offer", price: "0", priceCurrency: "SGD" },
  publisher: { "@type": "Organization", name: SITE.name, url: SITE.url },
  inLanguage: "en-SG",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={pageUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={SITE.locale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("sgutils-theme");
          if (stored === "dark" || stored === "light") {
            document.documentElement.dataset.theme = stored;
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand">sgutils</a>
      <nav>
        <a href="#validate">Validate</a>
        <button
          id="theme-toggle"
          type="button"
          class="icon-btn"
          aria-label="Toggle theme"
          title="Toggle theme"
        >
          <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path></svg>
          <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
        </button>
      </nav>
    </header>

    <main>
      <section class="hero">
        <h1>Singapore NRIC &amp; FIN Generator</h1>
        <p class="lede">
          Generate format-valid test identifiers for development and QA. All
          computation runs in your browser — nothing is sent anywhere.
        </p>
      </section>

      <section class="card" aria-labelledby="generate-heading">
        <h2 id="generate-heading">Generate</h2>

        <div class="field">
          <span class="label">Type</span>
          <div class="segmented" role="radiogroup" aria-label="ID type">
            <label>
              <input type="radio" name="kind" value="NRIC" checked />
              <span>NRIC</span>
            </label>
            <label>
              <input type="radio" name="kind" value="FIN" />
              <span>FIN</span>
            </label>
          </div>
        </div>

        <div class="row">
          <div class="field">
            <label for="prefix" class="label">Prefix</label>
            <select id="prefix">
              <option value="S">S — {PREFIX_DESCRIPTIONS.S}</option>
              <option value="T">T — {PREFIX_DESCRIPTIONS.T}</option>
              <option value="F" hidden>F — {PREFIX_DESCRIPTIONS.F}</option>
              <option value="G" hidden>G — {PREFIX_DESCRIPTIONS.G}</option>
              <option value="M" hidden>M — {PREFIX_DESCRIPTIONS.M}</option>
            </select>
          </div>

          <div class="field">
            <label for="count" class="label">How many</label>
            <select id="count">
              <option selected>1</option>
              <option>5</option>
              <option>10</option>
              <option>20</option>
              <option>50</option>
            </select>
          </div>
        </div>

        <button id="generate-btn" class="primary" type="button">Generate</button>

        <div class="results-header" hidden>
          <span id="results-count"></span>
          <button id="copy-all" class="ghost" type="button">Copy all</button>
        </div>
        <ul id="results" class="results" aria-live="polite"></ul>

        <p class="disclaimer">
          For testing and development only. These are <strong>not</strong> real
          identities and must not be used to impersonate anyone or bypass
          identity checks.
        </p>
      </section>

      <section class="card" id="validate" aria-labelledby="validate-heading">
        <h2 id="validate-heading">Validate</h2>
        <div class="row">
          <div class="field grow">
            <label for="validate-input" class="label">NRIC or FIN</label>
            <input
              id="validate-input"
              type="text"
              inputmode="text"
              autocomplete="off"
              spellcheck="false"
              placeholder="e.g. S1234567D"
              maxlength="9"
            />
          </div>
          <div class="field">
            <span class="label">&nbsp;</span>
            <button id="validate-btn" class="primary" type="button">Check</button>
          </div>
        </div>
        <p id="validate-result" class="validate-result" aria-live="polite"></p>
      </section>
    </main>

    <footer class="site-footer">
      <p>© {new Date().getFullYear()} sgutils — open utilities for Singapore.</p>
    </footer>
  </body>
</html>

<script>
  import {
    generateMany,
    validate,
    type IdPrefix,
  } from "../lib/identifiers";

  const kindRadios = document.querySelectorAll<HTMLInputElement>(
    'input[name="kind"]',
  );
  const prefixSelect = document.getElementById("prefix") as HTMLSelectElement;
  const countSelect = document.getElementById("count") as HTMLSelectElement;
  const generateBtn = document.getElementById(
    "generate-btn",
  ) as HTMLButtonElement;
  const resultsList = document.getElementById("results") as HTMLUListElement;
  const resultsHeader = document.querySelector(
    ".results-header",
  ) as HTMLDivElement;
  const resultsCountEl = document.getElementById(
    "results-count",
  ) as HTMLSpanElement;
  const copyAllBtn = document.getElementById("copy-all") as HTMLButtonElement;

  const validateInput = document.getElementById(
    "validate-input",
  ) as HTMLInputElement;
  const validateBtn = document.getElementById(
    "validate-btn",
  ) as HTMLButtonElement;
  const validateResultEl = document.getElementById(
    "validate-result",
  ) as HTMLParagraphElement;

  const NRIC_PREFIXES = ["S", "T"];
  const FIN_PREFIXES = ["F", "G", "M"];

  function currentKind(): "NRIC" | "FIN" {
    const checked = Array.from(kindRadios).find((r) => r.checked);
    return (checked?.value as "NRIC" | "FIN") ?? "NRIC";
  }

  function syncPrefixOptions() {
    const kind = currentKind();
    const allowed = kind === "NRIC" ? NRIC_PREFIXES : FIN_PREFIXES;
    let firstVisible: string | null = null;
    for (const opt of Array.from(prefixSelect.options)) {
      const show = allowed.includes(opt.value);
      opt.hidden = !show;
      opt.disabled = !show;
      if (show && firstVisible === null) firstVisible = opt.value;
    }
    if (!allowed.includes(prefixSelect.value) && firstVisible) {
      prefixSelect.value = firstVisible;
    }
  }

  kindRadios.forEach((r) => r.addEventListener("change", syncPrefixOptions));
  syncPrefixOptions();

  async function copyText(text: string, btn: HTMLButtonElement) {
    try {
      await navigator.clipboard.writeText(text);
      const prev = btn.textContent;
      btn.textContent = "Copied";
      btn.classList.add("copied");
      setTimeout(() => {
        btn.textContent = prev;
        btn.classList.remove("copied");
      }, 1200);
    } catch {
      btn.textContent = "Copy failed";
    }
  }

  function renderResults(ids: string[]) {
    resultsList.innerHTML = "";
    for (const id of ids) {
      const li = document.createElement("li");
      const code = document.createElement("code");
      code.textContent = id;
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "ghost";
      btn.textContent = "Copy";
      btn.addEventListener("click", () => copyText(id, btn));
      li.append(code, btn);
      resultsList.append(li);
    }
    resultsHeader.hidden = ids.length === 0;
    resultsCountEl.textContent =
      ids.length === 1 ? "1 result" : `${ids.length} results`;
  }

  generateBtn.addEventListener("click", () => {
    const prefix = prefixSelect.value as IdPrefix;
    const count = Number.parseInt(countSelect.value, 10);
    const ids = generateMany(prefix, count);
    renderResults(ids);
  });

  copyAllBtn.addEventListener("click", () => {
    const text = Array.from(resultsList.querySelectorAll("code"))
      .map((c) => c.textContent ?? "")
      .join("\n");
    if (text) copyText(text, copyAllBtn);
  });

  function runValidate() {
    const value = validateInput.value;
    if (!value.trim()) {
      validateResultEl.textContent = "";
      validateResultEl.className = "validate-result";
      return;
    }
    const result = validate(value);
    if (result.valid) {
      validateResultEl.textContent = `✓ Valid ${result.kind} (prefix ${result.prefix})`;
      validateResultEl.className = "validate-result ok";
    } else {
      validateResultEl.textContent = `✗ Invalid — ${result.reason}`;
      validateResultEl.className = "validate-result err";
    }
  }

  validateBtn.addEventListener("click", runValidate);
  validateInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter") runValidate();
  });

  const themeToggle = document.getElementById("theme-toggle") as HTMLButtonElement;
  const mql = window.matchMedia("(prefers-color-scheme: dark)");

  function effectiveTheme(): "light" | "dark" {
    const stored = localStorage.getItem("sgutils-theme");
    if (stored === "light" || stored === "dark") return stored;
    return mql.matches ? "dark" : "light";
  }

  function updateToggleLabel() {
    const next = effectiveTheme() === "dark" ? "light" : "dark";
    themeToggle.setAttribute("aria-label", `Switch to ${next} mode`);
    themeToggle.setAttribute("title", `Switch to ${next} mode`);
  }

  themeToggle.addEventListener("click", () => {
    const next = effectiveTheme() === "dark" ? "light" : "dark";
    localStorage.setItem("sgutils-theme", next);
    document.documentElement.dataset.theme = next;
    updateToggleLabel();
  });

  mql.addEventListener("change", () => {
    if (!localStorage.getItem("sgutils-theme")) updateToggleLabel();
  });

  updateToggleLabel();
</script>

<style is:global>
  :root {
    --bg: #fafaf8;
    --panel: #ffffff;
    --text: #1a1a1a;
    --muted: #666;
    --border: #e3e3e0;
    --primary: #3b82f6;
    --primary-hover: #2563eb;
    --ok: #0b8043;
    --err: #c0372a;
    --segmented-bg: #f0f0ec;
    --disclaimer-bg: #fff7e6;
    --disclaimer-border: #f3dfa0;
    --disclaimer-text: #664d00;
    --shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
    --radius: 10px;
    --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    --sans:
      system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial,
      sans-serif;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) {
      --bg: #0f0f10;
      --panel: #1a1a1c;
      --text: #ececec;
      --muted: #9a9a9d;
      --border: #2a2a2d;
      --primary: #60a5fa;
      --primary-hover: #3b82f6;
      --ok: #43c17a;
      --err: #ff6a5b;
      --segmented-bg: #232326;
      --disclaimer-bg: #2a2414;
      --disclaimer-border: #4a3f1f;
      --disclaimer-text: #f2d889;
      --shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
    }
  }

  :root[data-theme="dark"] {
    --bg: #0f0f10;
    --panel: #1a1a1c;
    --text: #ececec;
    --muted: #9a9a9d;
    --border: #2a2a2d;
    --primary: #60a5fa;
    --primary-hover: #3b82f6;
    --ok: #43c17a;
    --err: #ff6a5b;
    --segmented-bg: #232326;
    --disclaimer-bg: #2a2414;
    --disclaimer-border: #4a3f1f;
    --disclaimer-text: #f2d889;
    --shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--text);
    line-height: 1.5;
    transition: background 0.15s, color 0.15s;
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
    background: var(--panel);
  }

  .brand {
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--text);
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .site-header nav {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .site-header nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .icon-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    width: 36px;
    height: 36px;
    min-height: 36px;
    padding: 0;
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .icon-btn:hover {
    color: var(--text);
    border-color: var(--text);
  }

  /* Default (no override): assume light — show sun icon */
  .icon-btn .icon-sun { display: block; }
  .icon-btn .icon-moon { display: none; }

  /* OS dark, no override: show moon */
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .icon-btn .icon-sun { display: none; }
    :root:not([data-theme="light"]) .icon-btn .icon-moon { display: block; }
  }

  /* Explicit overrides always win */
  :root[data-theme="dark"] .icon-btn .icon-sun { display: none; }
  :root[data-theme="dark"] .icon-btn .icon-moon { display: block; }
  :root[data-theme="light"] .icon-btn .icon-sun { display: block; }
  :root[data-theme="light"] .icon-btn .icon-moon { display: none; }

  main {
    max-width: 640px;
    margin: 0 auto;
    padding: 1.5rem 1rem 3rem;
  }

  .hero h1 {
    font-size: 1.6rem;
    margin: 0.5rem 0 0.5rem;
    letter-spacing: -0.015em;
  }

  .lede {
    color: var(--muted);
    margin: 0 0 1.5rem;
  }

  .card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .card h2 {
    margin: 0 0 1rem;
    font-size: 1.15rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 0.9rem;
  }

  .field.grow { flex: 1; }

  .label {
    font-size: 0.82rem;
    color: var(--muted);
    font-weight: 500;
  }

  .row {
    display: flex;
    gap: 0.75rem;
    align-items: flex-end;
  }

  .row .field {
    flex: 1;
    margin-bottom: 0.9rem;
  }

  select, input[type="text"] {
    font-family: var(--sans);
    font-size: 1rem;
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--panel);
    color: var(--text);
    width: 100%;
    min-height: 44px;
  }

  input[type="text"] {
    font-family: var(--mono);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  select:focus, input:focus, button:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 1px;
  }

  .segmented {
    display: inline-flex;
    background: var(--segmented-bg);
    border-radius: 8px;
    padding: 3px;
    gap: 2px;
  }

  .segmented label { position: relative; }

  .segmented input {
    position: absolute;
    opacity: 0;
    inset: 0;
  }

  .segmented span {
    display: inline-block;
    padding: 0.5rem 1.1rem;
    border-radius: 6px;
    font-weight: 500;
    cursor: pointer;
    min-width: 72px;
    text-align: center;
    color: var(--muted);
  }

  .segmented input:checked + span {
    background: var(--panel);
    color: var(--text);
    box-shadow: var(--shadow);
  }

  button {
    font-family: var(--sans);
    font-size: 0.98rem;
    border-radius: 8px;
    padding: 0.7rem 1.1rem;
    cursor: pointer;
    min-height: 44px;
    border: 1px solid transparent;
    transition: background 0.15s, border-color 0.15s;
  }

  button.primary {
    background: var(--primary);
    color: #fff;
    border-color: var(--primary);
    width: 100%;
    font-weight: 600;
  }

  button.primary:hover {
    background: var(--primary-hover);
    border-color: var(--primary-hover);
  }

  button.ghost {
    background: transparent;
    color: var(--muted);
    border-color: var(--border);
    padding: 0.35rem 0.7rem;
    min-height: 32px;
    font-size: 0.85rem;
  }

  button.ghost:hover {
    border-color: var(--text);
    color: var(--text);
  }

  button.ghost.copied {
    color: var(--ok);
    border-color: var(--ok);
  }

  .results-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.88rem;
  }

  .results {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0;
  }

  .results li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--border);
    gap: 0.5rem;
  }

  .results li:last-child { border-bottom: none; }

  .results code {
    font-family: var(--mono);
    font-size: 1rem;
    letter-spacing: 0.05em;
    user-select: all;
  }

  .disclaimer {
    margin-top: 1rem;
    padding: 0.75rem 0.9rem;
    background: var(--disclaimer-bg);
    border: 1px solid var(--disclaimer-border);
    border-radius: 8px;
    font-size: 0.85rem;
    color: var(--disclaimer-text);
  }

  .validate-result {
    margin: 0.75rem 0 0;
    font-family: var(--mono);
    font-size: 0.95rem;
    min-height: 1.5em;
  }

  .validate-result.ok { color: var(--ok); }
  .validate-result.err { color: var(--err); }

  .site-footer {
    text-align: center;
    color: var(--muted);
    font-size: 0.85rem;
    padding: 2rem 1rem;
  }

  @media (max-width: 420px) {
    .row {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }
  }
</style>
